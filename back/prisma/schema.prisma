generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  projects Project[]

  @@map("users")
}

model Project {
  id           String   @id @default(uuid())
  name         String   @unique
  slug         String   @unique
  image        String?
  phoneNumber  String   @map("phone_number")
  agency       String?
  templateSid  String   @map("template_sid")
  flowMessage  String   @map("flow_message") @db.Text
  apiKey       String   @unique @map("api_key")
  zabbixHostName String? @map("zabbix_host_name")
  userId       String   @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  numbers       Number[]
  mediaRequests MediaRequest[]
  zabbixMetricEvents ZabbixMetricEvent[]

  @@map("projects")
}

model Number {
  id        String   @id @default(uuid())
  name      String
  number    String
  projectId String   @map("project_id")
  createdAt DateTime @default(now()) @map("created_at")

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mediaRequests MediaRequest[]

  @@map("numbers")
}

enum MediaRequestStatus {
  PENDING
  TEMPLATE_SENT
  RECONFIRMATION_SENT
  DECLINED
  CONFIRMED
  MEDIA_SENT
  INVALID_RESPONSE_LIMIT
  FAILED
}

model MediaRequest {
  id        String             @id @default(uuid())
  mediaUrl  String             @map("media_url")
  status    MediaRequestStatus @default(PENDING)
  invalidReplyCount Int        @default(0) @map("invalid_reply_count")
  lastInvalidReplyAt DateTime? @map("last_invalid_reply_at")
  numberId  String             @map("number_id")
  projectId String             @map("project_id")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  number  Number  @relation(fields: [numberId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  zabbixMetricEvents ZabbixMetricEvent[]

  @@map("media_requests")
}

enum ZabbixMetricEventType {
  TEMPLATE_SENT
  YES_REPLY
  NO_REPLY
  INVALID_REPLY
  MEDIA_SENT
}

model ZabbixMetricEvent {
  id             String                @id @default(uuid())
  type           ZabbixMetricEventType
  projectId      String                @map("project_id")
  mediaRequestId String?               @map("media_request_id")
  createdAt      DateTime              @default(now()) @map("created_at")

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mediaRequest MediaRequest? @relation(fields: [mediaRequestId], references: [id], onDelete: SetNull)

  @@index([projectId, type])
  @@index([mediaRequestId])
  @@map("zabbix_metric_events")
}
